{
  "name": "@teaspill/conformance",
  "version": "0.1.0",
  "private": true,
  "description": "Conformance kit (T6.3): named scenarios asserting D2/D3 invariants against a live teaspill stack, with offline versions that run in CI. Reusable by T9.1's chaos suite.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "eslint src"
  },
  "dependencies": {
    "@teaspill/agents-sdk": "workspace:*",
    "@teaspill/coordination": "workspace:*",
    "@teaspill/executor": "workspace:*",
    "@teaspill/frontend-sdk": "workspace:*",
    "@teaspill/schema": "workspace:*"
  }
}
