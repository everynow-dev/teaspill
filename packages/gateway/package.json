{
  "name": "@teaspill/gateway",
  "version": "0.1.0",
  "private": true,
  "description": "Gateway service — single entrypoint for API, streams, shapes, and registry routes.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/testing/fake-durable-streams.d.ts",
      "import": "./dist/testing/fake-durable-streams.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "eslint src",
    "start": "node dist/server.js",
    "bundle": "esbuild src/server.ts --bundle --platform=node --target=node22 --format=esm --outfile=dist/docker/server.mjs --banner:js=\"import { createRequire as __createRequire } from 'node:module'; const require = __createRequire(import.meta.url);\""
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/core": "2.9.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.220.0",
    "@opentelemetry/resources": "^2.9.0",
    "@opentelemetry/sdk-trace-node": "^2.9.0",
    "@teaspill/catalog": "workspace:*",
    "@teaspill/schema": "workspace:*",
    "drizzle-orm": "0.45.2",
    "fastify": "^5.10.0",
    "jose": "6.2.3",
    "ulidx": "^2.4.1",
    "undici": "^8.7.0"
  },
  "devDependencies": {
    "esbuild": "^0.28.1"
  }
}
