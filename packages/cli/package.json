{
  "name": "@teaspill/cli",
  "version": "0.1.0",
  "private": true,
  "description": "teaspill CLI — platform dev loop and agent inspection commands.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "teaspill": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "eslint src"
  },
  "dependencies": {
    "@teaspill/agents-sdk": "workspace:*",
    "@teaspill/catalog": "workspace:*",
    "@teaspill/frontend-sdk": "workspace:*",
    "@teaspill/schema": "workspace:*",
    "cac": "6.7.14"
  }
}
