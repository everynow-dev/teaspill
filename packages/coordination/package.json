{
  "name": "@teaspill/coordination",
  "version": "0.1.0",
  "private": true,
  "description": "Restate coordination services: agent objects, projection outbox, messaging, cron, control API, steerbox.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "eslint src"
  },
  "dependencies": {
    "@restatedev/restate-sdk": "1.16.2",
    "@teaspill/harness-native": "workspace:*",
    "@teaspill/schema": "workspace:*",
    "croner": "10.0.1"
  }
}
