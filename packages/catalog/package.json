{
  "name": "@teaspill/catalog",
  "version": "0.1.0",
  "private": true,
  "description": "Postgres catalog schema (entities, entity_tags, api_keys) + migrations. Shared owner of the D1 catalog store — written from coordination via ctx.run, read by the gateway (api_keys, shape proxying).",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "drizzle"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "eslint src",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/migrate-cli.ts"
  },
  "dependencies": {
    "drizzle-orm": "0.45.2",
    "postgres": "3.4.9"
  },
  "devDependencies": {
    "drizzle-kit": "0.31.10",
    "tsx": "4.23.1"
  }
}
