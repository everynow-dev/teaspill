# teaspill — self-host compose environment (T1.1)
#
# Copy to `.env` (gitignored) before running `make dev` / `docker compose up`:
#   cp .env.example .env
#
# Every variable docker-compose.yml references is documented here. All have
# working defaults baked into the compose file itself (`${VAR:-default}`),
# so an empty/missing .env still boots the stack — these are for anyone who
# wants non-default ports/credentials, not a hard requirement to fill in.

# --- Postgres (catalog store, D1) ---
# Also feeds Electric and, later, the gateway's own DATABASE_URL-backed
# reads (api_keys, T1.3). Change the password before ever exposing
# POSTGRES_PORT beyond localhost.
POSTGRES_USER=teaspill
POSTGRES_PASSWORD=teaspill
POSTGRES_DB=teaspill
# Host-side port Postgres is published on. Container-internal port is
# always 5432; this only affects `psql -h localhost -p <this>`.
POSTGRES_PORT=5432

# --- Restate (coordination core, D2) ---
# All four are host-side published ports; container-internal ports are
# fixed by the Restate server itself (8080/9070/9071/5122).
RESTATE_INGRESS_PORT=8080
RESTATE_ADMIN_PORT=9070
RESTATE_METRICS_PORT=9071
RESTATE_NODE_PORT=5122

# --- Electric (catalog sync to UIs via shapes, D1) ---
# Host-side published port for the shape API (container always listens on
# 3000 internally; see ELECTRIC_PORT in docker-compose.yml).
ELECTRIC_PORT_HOST=3000
# Dev-mode only. Skips ELECTRIC_SECRET auth on the shape API entirely.
# MUST be set to `false` (and ELECTRIC_SECRET set — not yet wired here,
# add when T1.2/T1.4 need it) before exposing Electric's port beyond
# localhost. See docs/self-hosting-networking.md.
ELECTRIC_INSECURE=true

# --- durable-streams (history/telemetry store, Rust server, D1/D3) ---
DURABLE_STREAMS_PORT=4437
# error | warn | info | debug | trace (Rust `RUST_LOG` filter syntax; e.g.
# `info,durable_streams_server=debug` also works).
DURABLE_STREAMS_LOG=info

# --- Gateway (single entrypoint, D6 — T1.2 implements the service) ---
GATEWAY_PORT=8787
